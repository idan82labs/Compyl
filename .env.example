# ReviewLayer — Environment Variables
# Copy to .env and fill in values.

# Neon PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI worker base URL (default: http://localhost:8001)
WORKER_AI_URL=http://localhost:8001

# Auth.js secret for session signing (required, generate with: openssl rand -base64 32)
AUTH_SECRET=

# Node environment (default: development)
NODE_ENV=development

# API server config
PORT=3001
HOST=0.0.0.0
